# Puerto del servidor
PORT=3000

# URL de base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_db

# URL del proveedor de pagos (Sandbox)
# NOTA: Usar placeholder, NO commitear URL real con nombre del proveedor
PAYMENT_PROVIDER_BASE_URL=https://api-sandbox.co.uat.payment-provider.dev/v1

# Claves del proveedor de pagos
# NOTA: Usar placeholders, NO commitear claves reales
PAYMENT_PROVIDER_PUBLIC_KEY=pub_placeholder_xxxxxxxxxxxxxx
PAYMENT_PROVIDER_PRIVATE_KEY=priv_placeholder_xxxxxxxxxxxxxx
PAYMENT_PROVIDER_EVENTS_KEY=events_placeholder_xxxxxxxxxxxxxx
PAYMENT_PROVIDER_INTEGRITY_SECRET=integrity_placeholder_xxxxxxxxxxxxxx
